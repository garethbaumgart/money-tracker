    "/households/invitations/{invitationToken}/accept": {
      "post": {
        "description": "Adds the authenticated user as a household member.",
        "operationId": "AcceptHouseholdInvitation",
        "parameters": [
          {
            "in": "path",
            "name": "invitationToken",
            "required": true,
