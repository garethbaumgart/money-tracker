{
  "Api": {
    "ServiceName": "MoneyTracker.Api",
    "Environment": "Production"
  },
  "Database": {
    "ConnectionString": "Host=placeholder;Database=money_tracker;Username=placeholder;Password=placeholder"
  },
  "Performance": {
    "ResponseTimeBudgets": {
      "Auth": 200,
      "Crud": 300,
      "Dashboard": 500,
      "Insights": 500,
      "BankSync": 1000,
      "Admin": 1000
    },
    "ConnectionPool": {
      "MinPoolSize": 5,
      "MaxPoolSize": 50,
      "ConnectionIdleLifetime": 300,
      "ConnectionLifetime": 3600
    }
  },
  "Alerting": {
    "ErrorRateThresholdPercent": 5,
    "ErrorRateWindowSeconds": 300
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
